# Trade Me Sandbox OAuth 1.0 (PLAINTEXT) credentials.
# Copy this file to `.env` and fill in your own values.
# Generate these at https://developer.trademe.co.nz/api-overview/authentication

CONSUMER_KEY=your_consumer_key
CONSUMER_SECRET=your_consumer_secret

TOKEN=your_oauth_token
TOKEN_SECRET=your_oauth_token_secret

# API base URL
API_BASE_URL=https://api.tmsandbox.co.nz/v1

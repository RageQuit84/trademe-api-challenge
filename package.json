{
  "name": "api-automation-challenge",
  "version": "1.0.0",
  "description": "Trade Me watchlist API regression tests (Playwright + TypeScript)",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "test": "playwright test",
    "test:api": "playwright test --project=api",
    "test:contract": "playwright test --project=contract",
    "report": "playwright show-report",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "playwright",
    "api-testing",
    "trademe",
    "pact",
    "contract-testing"
  ],
  "license": "MIT",
  "devDependencies": {
    "@pact-foundation/pact": "^16.5.0",
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.7.0",
    "dotenv": "^16.4.5",
    "typescript": "^5.6.0",
    "zod": "^3.23.8"
  }
}
